<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/background">

  <View
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:background="@drawable/bg_main_top_glow" />

  <com.google.android.material.appbar.AppBarLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:elevation="0dp">

    <com.google.android.material.appbar.MaterialToolbar
      android:id="@+id/toolbar"
      android:layout_width="match_parent"
      android:layout_height="?attr/actionBarSize"
      android:background="@android:color/transparent"
      android:paddingHorizontal="8dp"
      android:title="Settings"
      app:titleCentered="true"
      android:titleTextColor="@color/accent_emerald" />
  </com.google.android.material.appbar.AppBarLayout>

  <androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:contentPadding="16dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Protection Mode"
              android:textColor="@color/text_primary"
              android:textSize="28sp"
              android:textStyle="bold" />

            <ImageView
              android:layout_width="20dp"
              android:layout_height="20dp"
              android:src="@drawable/ic_shield"
              android:tint="@color/accent_emerald" />
          </LinearLayout>

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Configure target detection parameters."
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

          <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleBlurMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
              android:id="@+id/btnWomenOnly"
              style="?attr/materialButtonOutlinedStyle"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Women Only" />

            <com.google.android.material.button.MaterialButton
              android:id="@+id/btnAllFaces"
              style="?attr/materialButtonOutlinedStyle"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="All Faces" />

            <com.google.android.material.button.MaterialButton
              android:id="@+id/btnMenOnly"
              style="?attr/materialButtonOutlinedStyle"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Men Only" />
          </com.google.android.material.button.MaterialButtonToggleGroup>

          <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="14dp"
            android:background="@color/card_border" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Gender Threshold"
              android:textColor="@color/text_primary"
              android:textSize="16sp" />

            <TextView
              android:id="@+id/tvGenderValue"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="60%"
              android:textColor="@color/accent_emerald"
              android:textSize="16sp"
              android:textStyle="bold" />
          </LinearLayout>

          <com.google.android.material.slider.Slider
            android:id="@+id/sliderGenderThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:stepSize="0.05"
            android:value="0.6"
            android:valueFrom="0.5"
            android:valueTo="0.95" />

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lower = blur more aggressively when gender is uncertain"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_status_strip"
            android:gravity="center_vertical"
            android:minHeight="50dp"
            android:paddingHorizontal="12dp">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Detect Faces"
              android:textColor="@color/text_primary"
              android:textSize="15sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
              android:id="@+id/switchDetectFaces"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:checked="true" />
          </LinearLayout>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>

      <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:contentPadding="16dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Content Safety"
              android:textColor="@color/text_primary"
              android:textSize="28sp"
              android:textStyle="bold" />

            <ImageView
              android:layout_width="20dp"
              android:layout_height="20dp"
              android:src="@android:drawable/ic_dialog_alert"
              android:tint="@color/female_pink" />
          </LinearLayout>

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Adjust sensitivity for explicit content."
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="NSFW Sensitivity"
              android:textColor="@color/text_primary"
              android:textSize="16sp" />

            <TextView
              android:id="@+id/tvNsfwValue"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="0.50"
              android:textColor="@color/female_pink"
              android:textSize="16sp"
              android:textStyle="bold" />
          </LinearLayout>

          <com.google.android.material.slider.Slider
            android:id="@+id/sliderNsfwThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:stepSize="0.05"
            android:value="0.5"
            android:valueFrom="0.1"
            android:valueTo="0.95" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Strict"
              android:textColor="@color/text_secondary"
              android:textSize="12sp" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Lenient"
              android:textColor="@color/text_secondary"
              android:textSize="12sp" />
          </LinearLayout>

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Content is blurred when NSFW score exceeds this threshold"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_status_strip"
            android:gravity="center_vertical"
            android:minHeight="50dp"
            android:paddingHorizontal="12dp">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Detect NSFW"
              android:textColor="@color/text_primary"
              android:textSize="15sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
              android:id="@+id/switchDetectNsfw"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:checked="true" />
          </LinearLayout>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>

      <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:contentPadding="16dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Appearance"
              android:textColor="@color/text_primary"
              android:textSize="28sp"
              android:textStyle="bold" />

            <ImageView
              android:layout_width="20dp"
              android:layout_height="20dp"
              android:src="@android:drawable/ic_menu_view"
              android:tint="@color/text_secondary" />
          </LinearLayout>

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Blur Intensity"
              android:textColor="@color/text_primary"
              android:textSize="16sp" />

            <TextView
              android:id="@+id/tvBlurValue"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="85"
              android:textColor="@color/accent_emerald"
              android:textSize="16sp"
              android:textStyle="bold" />
          </LinearLayout>

          <com.google.android.material.slider.Slider
            android:id="@+id/sliderBlurIntensity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:stepSize="5"
            android:value="85"
            android:valueFrom="0"
            android:valueTo="100" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="None"
              android:textColor="@color/text_secondary"
              android:textSize="12sp" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Maximum"
              android:textColor="@color/text_secondary"
              android:textSize="12sp" />
          </LinearLayout>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>

      <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:contentPadding="16dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical">

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backend Configuration"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Connection details for inference engine."
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

          <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Backend URL"
            app:boxBackgroundMode="outline"
            app:helperText="http://10.0.2.2:3001 for emulator | http://192.168.x.x:3001 for device">

            <com.google.android.material.textfield.TextInputEditText
              android:id="@+id/etBackendUrl"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:inputType="textUri" />
          </com.google.android.material.textfield.TextInputLayout>

          <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestConnection"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Test Connection" />

          <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

          <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/accent_emerald"
            android:text="Save URL"
            android:textColor="@color/background" />
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>

      <com.google.android.material.button.MaterialButton
        android:id="@+id/btnResetDefaults"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="24dp"
        android:text="Reset to Defaults"
        android:textColor="@color/danger_red"
        app:strokeColor="@color/danger_red" />
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
